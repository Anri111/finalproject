# Copy this file to `.env` and fill in real values. Never commit `.env`.

# MongoDB connection string.
#   Local:  mongodb://127.0.0.1:27017/recipe-finder
#   Atlas:  mongodb+srv://<user>:<pass>@<cluster>/recipe-finder
MONGODB_URI=

# Long random string used to sign the session cookie.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Where the frontend runs (must match exactly for CORS + cookies).
CLIENT_ORIGIN=http://localhost:5173

# Port the API listens on.
PORT=4000
